{
  "name": "mstack",
  "version": "0.1.0",
  "private": true,
  "description": "Cursor workflow pack (rules, templates, docs) with optional reference Ideas HTTP API in src/",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --watch --import tsx src/server.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "mstack:doctor": "bash scripts/mstack-doctor.sh .",
    "mstack:verify-packs": "bash scripts/verify-packs-internal.sh",
    "mstack:ci": "bash scripts/mstack-ci-local.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
